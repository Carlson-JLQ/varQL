# Copy this file to .env and fill in your values
# Run: cp .env.example .env && echo "APP_UID=$(id -u)" >> .env && echo "APP_GID=$(id -g)" >> .env

# Docker user mapping (must match your host UID/GID to avoid permission issues with volume mounts)
APP_UID=1000
APP_GID=1000

# Host paths for tool installations (defaults shown)
# Recommended setup for this repository:
#   CodeQL bundle: /opt/codeql-bundle-2.23.3/codeql
#   CodeQL LSP MCP: /root/varQL/codeql-lsp-mcp
CODEQL_HOME=/opt/codeql-bundle-2.23.3/codeql
CODEQL_LSP_MCP_PATH=/root/varQL/codeql-lsp-mcp

# Optional explicit CLI/search-path configuration
CODEQL_PATH=/opt/codeql-bundle-2.23.3/codeql/codeql
CODEQL_SEARCH_PATH=/opt/codeql-bundle-2.23.3/codeql

# QL pack paths (version numbers depend on your CodeQL version)
# Find versions with:
#   ls ~/codeql/qlpacks/codeql/java-queries/   → use for SECURITY_QLPACK_PATH
#   ls ~/codeql/qlpacks/codeql/java-all/        → use for LIBRARY_QLPACK_PATH
# also can configure for other codeql supported languages
SECURITY_QLPACK_PATH=/opt/codeql-bundle-2.23.3/codeql/qlpacks/codeql/java-queries/1.8.2/Security/CWE
LIBRARY_QLPACK_PATH=/opt/codeql-bundle-2.23.3/codeql/qlpacks/codeql/java-all/7.7.2/semmle/code/java

# Chroma persistent storage used by the migrated fetchers / caches
CHROMA_DB_PATH=/root/varQL/data/chroma_db

# API Keys
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
GEMINI_API_KEY=
OPENAI_API_KEY=
